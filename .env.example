# Variables d'environnement pour Empreintes (GT BDDe AREP)
# Copier ce fichier en .env et remplir les valeurs si besoin.
# .env est gitignoré (jamais commit), env.example est versionné comme template.

# Port d'écoute du backend (par défaut 8000)
PORT=8000

# Origines autorisées pour CORS (séparées par virgules)
# En local : http://localhost:5500
# En prod  : https://arep-bdde.onrender.com
ALLOWED_ORIGINS=*

# URL de base du backend (utilisée par le frontend si servi séparément)
BACKEND_URL=http://localhost:8000
